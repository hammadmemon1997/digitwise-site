{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/pay-calculator",
      "dest": "/pay-calculator.html"
    },
    {
      "src": "/paycalc",
      "dest": "/pay-calculator.html"
    },
    {
      "src": "/about",
      "dest": "/about.html"
    },
    {
      "src": "/services",
      "dest": "/services.html"
    },
    {
      "src": "/pricing",
      "dest": "/pricing.html"
    },
    {
      "src": "/blog",
      "dest": "/blog.html"
    },
    {
      "src": "/contact",
      "dest": "/contact.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}